   "source": [
    "# sum of all factor digit"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "7ae776ac-6484-421a-8ffe-94877ee833c7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter any number 10\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "18\n"
     ]
    }
   ],
   "source": [
    "def sumOfAllFactorDigit(n):\n",
    "    sum=0\n",
    "    for i in range(1,n+1):\n",
    "        if n%i==0:\n",
    "            sum =sum+i\n",
    "    return sum\n",
    "n= int(input(\"Enter any number\"))\n",
    "print(sumOfAllFactorDigit(n))"
   ]
  },
