   "source": [
    "# Prime Number\n",
    "2,13,17,29 etc is called a prime number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "cf16c02e-9652-4183-88dc-6daf42b1aaa1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter any number 59\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "def primeNumber(n):\n",
    "    if n<=1:\n",
    "        return False\n",
    "    for i in range(2, int(n**0.5+1)):\n",
    "        if n%i==0:\n",
    "            return False\n",
    "    return True\n",
    "        \n",
    "n=int(input(\"Enter any number\"))\n",
    "print(primeNumber(n))\n",
    "    "
   ]
  },
