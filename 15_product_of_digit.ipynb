   "source": [
    "# Product of digits"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "0cdc02e4-2282-411c-8573-9f51272106a4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "enter any number 123456\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "720\n"
     ]
    }
   ],
   "source": [
    "def productOfDigit(n):\n",
    "    prod =1\n",
    "    while(n!=0):\n",
    "        prod = prod*(n%10)\n",
    "        n= n//10\n",
    "    return prod\n",
    "n= int(input(\"enter any number\"))\n",
    "print(productOfDigit(n))"
   ]
  },
