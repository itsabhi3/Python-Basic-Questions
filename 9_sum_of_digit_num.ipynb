    "def sumOfDigit(n):\n",
    "    sum =0\n",
    "    while(n!=0):\n",
    "       sum = sum + (n%10)\n",
    "        n=n//10\n",
    "        \n",
    "    return sum\n",
    "\n",
    "n=int(input(\"Enter any number\"))\n",
    "print(sumOfDigit(n))"
   ]
