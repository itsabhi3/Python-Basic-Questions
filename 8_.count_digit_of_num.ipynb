   "source": [
    "# Count the number of digit in a number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "ab6778cf-0b48-45cd-aaf4-ea30a5201c90",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "enter any number 234566\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "6\n"
     ]
    }
   ],
   "source": [
    "def countDigit(n):\n",
    "    count = 0\n",
    "    while(n!=0):\n",
    "        n = n//10\n",
    "        count+=1\n",
    "    return count\n",
    "\n",
    "n=int(input(\"enter any number\"))\n",
    "print(countDigit(n))\n"
   ]
  },
