   ],
   "source": [
    "def printFactors(n):\n",
    "    for i in range(1, n+1):\n",
    "        if n%i==0:\n",
    "            print(i)\n",
    "        \n",
    "n=int(input(\"Enter any number\"))\n",
    "(printFactors(n))"
   ]
  },
