   "source": [
    "# Print the Reverse number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "8b214bce-4d84-4124-9997-f8b88db9351d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter any number 4567\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "7654\n"
     ]
    }
   ],
   "source": [
    "def reverseNumber(n):\n",
    "    temp = 0\n",
    "    while(n!=0):\n",
    "        temp = temp*10 + (n%10)\n",
    "        n=n//10\n",
    "    return temp\n",
    "n=int(input(\"Enter any number\"))\n",
    "print(reverseNumber(n))"
   ]
  },
