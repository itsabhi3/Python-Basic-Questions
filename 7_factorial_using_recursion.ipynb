   "source": [
    "# factorial using recustion\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "c56726b5-a21c-450d-8366-b68c5d82c978",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter any number 5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "120\n"
     ]
    }
   ],
   "source": [
    "def factorial(n):\n",
    "    if(n==0):\n",
    "        return 1\n",
    "    return n*factorial(n-1)\n",
    "n=int(input(\"Enter any number\"))\n",
    "print(factorial(n))"
   ]
  },
