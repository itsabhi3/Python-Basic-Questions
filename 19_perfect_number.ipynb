   "source": [
    "# Perfect number\n",
    "6,28,496 etc. is called perfect number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "6be70f12-3055-4541-9610-1ab08f88387e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "enter any number 496\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "def perfectNumber(n):\n",
    "    sum =0\n",
    "    for i in range(1, n//2+1):\n",
    "        if n%i==0:\n",
    "            sum =sum+i\n",
    "    if sum == n:\n",
    "        return True\n",
    "    return False\n",
    "\n",
    "n=int(input(\"enter any number\"))\n",
    "print(perfectNumber(n))"
   ]
  },
