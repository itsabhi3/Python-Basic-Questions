   "source": [
    "# LCM of two number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "462adc8c-dce4-4838-824d-09606e60aa03",
   "metadata": {},
   "outputs": [],
   "source": [
    "def lcm(a,b):\n",
    "    maximum=max(a,b)\n",
    "    i=maximum\n",
    "    while(1):\n",
    "        if maximum%a ==0 and maximum%b ==0:\n",
    "            return maximum\n",
    "        maximum=maximum+i\n",
    "a=int(input(\"Enter first number\"))\n",
    "b=int(input(\"Enter second number\"))\n",
    "print(lcm(a,b))\n"
   ]
  },
