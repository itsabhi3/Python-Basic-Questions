   "source": [
    "def perfectSquare(n):\n",
    "    sq = n**0.5\n",
    "    if sq == int(sq):\n",
    "        return True\n",
    "    return False\n",
    "n=int(input(\"Enter any number\"))\n",
    "print(perfectSquare(n))\n",
    "    "
   ]
