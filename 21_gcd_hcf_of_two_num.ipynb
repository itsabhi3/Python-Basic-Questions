   "source": [
    "# GCD/HCF of two numbers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "cd25646e-30ed-4d10-b5ed-c70adcf0eb84",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter first number 12\n",
      "enter second number 18\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "6\n"
     ]
    }
   ],
   "source": [
    "def gcd(a,b):\n",
    "    if(b==0):\n",
    "        return a\n",
    "    return gcd(b,a%b)\n",
    "a=int(input(\"Enter first number\"))\n",
    "b=int(input(\"enter second number\"))\n",
    "print(gcd(a,b))"
   ]
  },
