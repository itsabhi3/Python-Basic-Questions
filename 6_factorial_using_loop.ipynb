   "source": [
    "\n",
    "# Factorial of a number usning iteration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "6cdcba82-9b22-4ccb-aadd-ae4dfdcffdfd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "enter any number 6\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "720\n"
     ]
    }
   ],
   "source": [
    "def factorial(n):\n",
    "    fact=1\n",
    "    while(n!=0):\n",
    "        fact=fact*n\n",
    "        n=n-1\n",
    "    return fact\n",
    "n=int(input(\"enter any number\"))\n",
    "print(factorial(n))"
   ]
  },
